# Memo 环境配置
# 复制为 .env 并填入实际值

# LLM API（DeepSeek 或 OpenAI 兼容接口）
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.deepseek.com/v1

# 提取用模型（记忆会持续消耗 token，轻量便宜即可，默认推荐 deepseek-v4-flash；更强可选 deepseek-v4-pro）
MEMO_EXTRACTION_MODEL=deepseek-v4-flash
MEMO_GATING_MODEL=deepseek-v4-flash

# 嵌入模型（留空使用本地 BGE-small）
MEMO_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# 数据库路径（默认 data/memo.db，也可指定绝对路径）
MEMO_DB_PATH=data/memo.db

# 日志级别
MEMO_LOG_LEVEL=INFO
